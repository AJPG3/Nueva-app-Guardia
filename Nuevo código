<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>GC MASTER ELITE - SISTEMA INTEGRAL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; -webkit-tap-highlight-color: transparent; overflow: hidden; background-color: #f8fafc; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .active-scale:active { transform: scale(0.96); }
        .glass-header { background: linear-gradient(135deg, #043d26 0%, #08633e 100%); position: sticky; top: 0; z-index: 50; }
        .main-scroll-area { height: calc(100vh - 80px); overflow-y: auto; padding-bottom: 160px; }
        .nav-active { color: #34d399 !important; border-top: 3px solid #34d399; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-card { animation: fadeIn 0.3s ease-out forwards; }
        .gold-gradient { background: linear-gradient(135deg, #b45309 0%, #d97706 100%); }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        const apiKey = ""; 
        const modelId = "gemini-2.5-flash-preview-09-2025";

        const TEMARIO_2025 = [
            "Derechos Humanos", "Igualdad", "Prevención Riesgos", "Constitucional", "Derecho UE",
            "Inst. Internacionales", "Derecho Civil", "Derecho Penal", "Procesal Penal", "Derecho Administrativo",
            "Protección Datos", "Extranjería", "Seguridad Pública", "Interior y Defensa", "FCS",
            "Guardia Civil", "Protección Civil", "Tecnologías", "Topografía", "Deontología",
            "Menores", "Armas y Explosivos", "Psicotécnicos", "Inglés", "Ortografía y Gramática"
        ].map((name, i) => ({ id: i + 1, name }));

        const EXAMENES_OFICIALES = [
            { year: "2025", label: "OFICIAL 2025 (Simulacro Real)", prompts: "Examen oficial Guardia Civil 2025 completo" },
            { year: "2024", label: "OFICIAL 2024 (Real)", prompts: "Examen real Guardia Civil 2024 con todas sus preguntas" },
            { year: "2023", label: "OFICIAL 2023 (Real)", prompts: "Examen real Guardia Civil 2023 con todas sus preguntas" }
        ];

        const PREGUNTAS_REPETIDAS_TEMAS = [
            "Art. 17 CE: Detención Preventiva", "Art. 520 LECrim: Derechos del Detenido", "LO 2/86: Funciones de la GC", "Código Penal: Penas y Medidas", "Tratado de Lisboa", "Estructura del Ministerio del Interior"
        ];

        const App = () => {
            const [view, setView] = useState('home');
            const [activeTab, setActiveTab] = useState('temas');
            const [loading, setLoading] = useState(false);
            const [failedPool, setFailedPool] = useState([]);
            const [numQ, setNumQ] = useState(20);
            const [selectedTarget, setSelectedTarget] = useState(null);
            const [test, setTest] = useState({ questions: [], current: 0, answers: {}, source: '' });
            const [showExitConfirm, setShowExitConfirm] = useState(false);

            // Cargar errores desde memoria (simulado, idealmente localstorage)
            useEffect(() => {
                const stored = localStorage.getItem('gc_failed_questions');
                if (stored) setFailedPool(JSON.parse(stored));
            }, []);

            const saveFailed = (q) => {
                const exists = failedPool.find(item => item.q === q.q);
                if (!exists) {
                    const newPool = [...failedPool, q];
                    setFailedPool(newPool);
                    localStorage.setItem('gc_failed_questions', JSON.stringify(newPool));
                }
            };

            const removeFailed = (qText) => {
                const newPool = failedPool.filter(q => q.q !== qText);
                setFailedPool(newPool);
                localStorage.setItem('gc_failed_questions', JSON.stringify(newPool));
            };

            const startIATest = async (target, isOfficial = false) => {
                setLoading(true);
                const name = typeof target === 'string' ? target : target.name;
                
                let prompt = "";
                if (isOfficial) {
                    prompt = `Genera el examen OFICIAL REAL de la Guardia Civil de ${target.year}. 
                    Debes incluir las preguntas reales en el orden exacto del examen oficial. 
                    Si no tienes el acceso total al texto exacto, genera una simulación 100% fiel a la estructura del año ${target.year}.
                    Formato JSON: { "questions": [{ "q": "", "options": ["","","",""], "correct": 0, "expl": "" }] }`;
                } else {
                    prompt = `Genera un test de ${numQ} preguntas sobre "${name}" para oposiciones a Guardia Civil.
                    Nivel de dificultad: Máximo. Incluye Psicotécnicos e Inglés si el tema lo requiere.
                    Formato JSON: { "questions": [{ "q": "", "options": ["","","",""], "correct": 0, "expl": "" }] }`;
                }
                
                try {
                    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${modelId}:generateContent?key=${apiKey}`, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ 
                            contents: [{ parts: [{ text: prompt }] }],
                            generationConfig: { responseMimeType: "application/json" }
                        })
                    });
                    const data = await response.json();
                    const json = JSON.parse(data.candidates[0].content.parts[0].text);
                    setTest({ questions: json.questions, current: 0, answers: {}, source: name });
                    setView('quiz');
                } catch (e) {
                    alert("Error al conectar con el servidor de exámenes. Comprueba tu conexión.");
                }
                setLoading(false);
            };

            const handleAnswer = (idx) => {
                if (test.answers[test.current] !== undefined) return;
                const correct = test.questions[test.current].correct;
                
                if (idx !== -1 && idx !== correct) {
                    saveFailed(test.questions[test.current]);
                }

                setTest(t => ({ ...t, answers: { ...t.answers, [t.current]: idx } }));
            };

            if (loading) return (
                <div className="h-screen bg-[#043d26] flex flex-col items-center justify-center text-white">
                    <div className="w-14 h-14 border-4 border-emerald-400 border-t-transparent rounded-full animate-spin mb-6"></div>
                    <p className="text-[10px] font-black uppercase tracking-[0.4em] animate-pulse">Sincronizando con Baeza...</p>
                </div>
            );

            return (
                <div className="max-w-md mx-auto bg-slate-50 h-screen flex flex-col shadow-2xl overflow-hidden relative">
                    {/* Confirmación Salida */}
                    {showExitConfirm && (
                        <div className="fixed inset-0 z-[200] bg-black/80 backdrop-blur-md flex items-center justify-center p-6">
                            <div className="bg-white rounded-[2.5rem] p-8 w-full max-w-xs text-center shadow-2xl">
                                <h3 className="text-xl font-black uppercase italic mb-2 text-slate-800 tracking-tighter">¿Finalizar Sesión?</h3>
                                <p className="text-[10px] text-slate-400 mb-8 font-bold uppercase tracking-widest leading-loose">Se guardará tu progreso en la batería de errores.</p>
                                <div className="space-y-3">
                                    <button onClick={() => { setShowExitConfirm(false); setView('results'); }} className="w-full bg-red-500 text-white py-5 rounded-2xl font-black uppercase text-[10px] tracking-widest active-scale">Confirmar y Ver Notas</button>
                                    <button onClick={() => setShowExitConfirm(false)} className="w-full bg-slate-100 text-slate-500 py-5 rounded-2xl font-black uppercase text-[10px] tracking-widest active-scale">Seguir Estudiando</button>
                                </div>
                            </div>
                        </div>
                    )}

                    <header className="glass-header px-6 pt-14 pb-6 rounded-b-[3rem] shadow-xl shrink-0">
                        <div className="flex justify-between items-center mb-6">
                            <h1 className="text-2xl font-black italic text-white tracking-tighter">GC MASTER <span className="text-emerald-400">ELITE</span></h1>
                            <div className="bg-emerald-400/20 px-3 py-1 rounded-full border border-emerald-400/30">
                                <span className="text-[8px] font-black text-emerald-400 uppercase tracking-widest">v2025.02</span>
                            </div>
                        </div>

                        {view === 'home' && (
                            <div className="flex bg-black/20 p-1.5 rounded-2xl overflow-x-auto no-scrollbar backdrop-blur-md">
                                {[
                                    { id: 'temas', label: 'Temario 1-25' },
                                    { id: 'oficiales', label: 'Oficiales' },
                                    { id: 'repetidas', label: 'Repetidas' },
                                    { id: 'failed', label: 'Errores' }
                                ].map(tab => (
                                    <button 
                                        key={tab.id}
                                        onClick={() => setActiveTab(tab.id)}
                                        className={`flex-none px-4 py-2 text-[9px] font-black uppercase rounded-xl transition-all mr-1 ${activeTab === tab.id ? 'bg-white text-[#043d26]' : 'text-white/40'}`}
                                    >
                                        {tab.label}
                                    </button>
                                ))}
                            </div>
                        )}
                    </header>

                    <main className="main-scroll-area px-6 pt-6 no-scrollbar">
                        {view === 'home' && (
                            <div className="space-y-4">
                                {activeTab === 'temas' && (
                                    <div className="grid grid-cols-1 gap-3">
                                        {TEMARIO_2025.map(t => (
                                            <div key={t.id} onClick={() => { setSelectedTarget(t); setView('config'); }} className="bg-white p-5 rounded-[2rem] border border-slate-100 flex items-center gap-4 active-scale shadow-sm animate-card">
                                                <div className="w-10 h-10 bg-emerald-50 rounded-2xl flex items-center justify-center text-emerald-700 font-black text-xs">{t.id}</div>
                                                <div className="flex-1 font-bold text-slate-700 text-sm tracking-tight">{t.name}</div>
                                                <i className="fa-solid fa-chevron-right text-slate-200 text-[10px]"></i>
                                            </div>
                                        ))}
                                    </div>
                                )}

                                {activeTab === 'oficiales' && (
                                    <div className="space-y-4">
                                        {EXAMENES_OFICIALES.map(ex => (
                                            <div key={ex.year} onClick={() => startIATest(ex, true)} className="bg-white p-8 rounded-[2.5rem] border border-slate-100 flex justify-between items-center active-scale shadow-sm animate-card">
                                                <div>
                                                    <h3 className="text-lg font-black text-slate-800 italic uppercase">AÑO {ex.year}</h3>
                                                    <p className="text-[10px] font-bold text-emerald-600 mt-1 uppercase tracking-widest">{ex.label}</p>
                                                </div>
                                                <i className="fa-solid fa-file-signature text-3xl text-slate-100"></i>
                                            </div>
                                        ))}
                                    </div>
                                )}

                                {activeTab === 'repetidas' && (
                                    <div className="space-y-3">
                                        <div className="gold-gradient p-6 rounded-[2.5rem] text-white shadow-lg mb-6">
                                            <div className="flex items-center gap-2 mb-2">
                                                <i className="fa-solid fa-bolt-lightning text-amber-300"></i>
                                                <span className="text-[10px] font-black uppercase tracking-widest">Preguntas Frecuentes</span>
                                            </div>
                                            <p className="text-xs font-bold opacity-90 leading-tight">Conceptos que aparecen en casi todas las convocatorias oficiales.</p>
                                        </div>
                                        {PREGUNTAS_REPETIDAS_TEMAS.map((item, idx) => (
                                            <div key={idx} onClick={() => startIATest(item)} className="bg-white p-5 rounded-[2rem] border border-orange-50 flex items-center gap-4 active-scale shadow-sm">
                                                <div className="w-8 h-8 bg-orange-50 rounded-xl flex items-center justify-center text-orange-600"><i className="fa-solid fa-star text-[10px]"></i></div>
                                                <div className="flex-1 font-bold text-slate-700 text-xs italic">{item}</div>
                                            </div>
                                        ))}
                                    </div>
                                )}

                                {activeTab === 'failed' && (
                                    <div className="space-y-4">
                                        <div className="text-center py-6">
                                            <h3 className="text-xl font-black text-slate-800 mb-2 uppercase italic tracking-tighter">Batería de Errores</h3>
                                            <p className="text-slate-400 text-[10px] mb-8 font-black uppercase tracking-[0.2em]">{failedPool.length} Fallos acumulados</p>
                                            {failedPool.length > 0 && (
                                                <button onClick={() => { setTest({ questions: failedPool, current: 0, answers: {}, source: 'Entrenamiento de Errores' }); setView('quiz'); }} className="w-full bg-red-500 text-white py-5 rounded-[2rem] font-black uppercase text-[10px] tracking-[0.2em] shadow-xl shadow-red-100 active-scale">Iniciar Repaso de Fallos</button>
                                            )}
                                        </div>
                                        <div className="space-y-3 pb-20">
                                            {failedPool.map((q, idx) => (
                                                <div key={idx} className="bg-white p-6 rounded-[2rem] border border-red-50 flex flex-col gap-3 shadow-sm animate-card">
                                                    <p className="text-[11px] font-bold text-slate-700 leading-relaxed">{q.q}</p>
                                                    <div className="flex justify-between items-center">
                                                        <span className="text-[9px] font-black text-red-500 uppercase tracking-widest bg-red-50 px-3 py-1 rounded-lg">Fallo Guardado</span>
                                                        <button onClick={() => removeFailed(q.q)} className="text-[9px] font-black text-slate-300 uppercase tracking-widest hover:text-red-500 flex items-center gap-2">
                                                            <i className="fa-solid fa-check-double"></i> Borrar de Errores
                                                        </button>
                                                    </div>
                                                </div>
                                            ))}
                                            {failedPool.length === 0 && (
                                                <div className="text-center py-20 opacity-20 flex flex-col items-center">
                                                    <i className="fa-solid fa-shield-check text-4xl mb-4"></i>
                                                    <p className="text-[10px] font-black uppercase tracking-widest">Tu marcador de errores está limpio.</p>
                                                </div>
                                            )}
                                        </div>
                                    </div>
                                )}
                            </div>
                        )}

                        {view === 'config' && (
                            <div className="bg-white p-10 rounded-[3.5rem] shadow-2xl border border-slate-50 animate-card text-center">
                                <h3 className="text-2xl font-black text-[#043d26] mb-2 uppercase italic tracking-tighter">{selectedTarget?.name}</h3>
                                <p className="text-slate-300 text-[9px] font-black uppercase tracking-widest mb-10">Parámetros del Test Personalizado</p>
                                <div className="flex gap-2 mb-10">
                                    {[10, 20, 50, 100].map(n => (
                                        <button key={n} onClick={() => setNumQ(n)} className={`flex-1 py-5 rounded-[1.5rem] font-black text-sm transition-all ${numQ === n ? 'bg-[#043d26] text-white shadow-xl' : 'bg-slate-50 text-slate-400 active-scale'}`}>{n}</button>
                                    ))}
                                </div>
                                <button onClick={() => startIATest(selectedTarget)} className="w-full bg-emerald-600 text-white py-6 rounded-[2.5rem] font-black active-scale shadow-xl shadow-emerald-50 uppercase tracking-[0.2em] text-[10px] mb-4">Generar Examen</button>
                                <button onClick={() => setView('home')} className="w-full py-4 text-[9px] font-black text-slate-300 uppercase tracking-widest active-scale">Cancelar</button>
                            </div>
                        )}

                        {view === 'quiz' && (
                            <div className="pb-32 animate-card">
                                <div className="bg-white p-8 rounded-[3.5rem] shadow-xl border border-slate-50 min-h-[550px] flex flex-col relative">
                                    <div className="flex justify-between items-center mb-8">
                                        <div className="flex flex-col">
                                            <span className="text-[9px] font-black text-emerald-600 uppercase tracking-widest truncate max-w-[150px]">{test.source}</span>
                                            <span className="text-[10px] font-black text-slate-300 uppercase mt-1 tracking-[0.2em]">{test.current + 1} / {test.questions.length}</span>
                                        </div>
                                        <button onClick={() => setShowExitConfirm(true)} className="px-5 py-2.5 bg-slate-900 text-white rounded-2xl text-[8px] font-black uppercase tracking-widest active-scale">Finalizar</button>
                                    </div>

                                    <div className="flex-1">
                                        <h2 className="text-lg font-bold text-slate-800 mb-10 leading-snug tracking-tight">{test.questions[test.current]?.q}</h2>
                                        <div className="space-y-3">
                                            {test.questions[test.current]?.options.map((opt, i) => {
                                                const answered = test.answers[test.current] !== undefined && test.answers[test.current] !== -1;
                                                const correct = test.questions[test.current].correct;
                                                const selected = i === test.answers[test.current];

                                                let style = "bg-slate-50 border-transparent text-slate-600";
                                                if (answered) {
                                                    if (i === correct) style = "bg-emerald-50 border-emerald-500 text-emerald-800 scale-[1.02] shadow-md";
                                                    else if (selected) style = "bg-red-50 border-red-500 text-red-800 opacity-80";
                                                    else style = "opacity-30 grayscale";
                                                }

                                                return (
                                                    <button key={i} onClick={() => handleAnswer(i)} className={`w-full p-5 rounded-[2rem] border-2 text-left text-sm font-semibold flex gap-4 transition-all duration-300 ${style}`}>
                                                        <span className={`w-7 h-7 shrink-0 rounded-xl flex items-center justify-center text-[10px] font-black ${answered && i === correct ? 'bg-emerald-500 text-white' : 'bg-white border'}`}>{String.fromCharCode(65+i)}</span>
                                                        <span className="flex-1">{opt}</span>
                                                    </button>
                                                );
                                            })}
                                        </div>
                                    </div>

                                    {(test.answers[test.current] !== undefined && test.answers[test.current] !== -1) && (
                                        <div className="mt-8 p-6 bg-slate-900 rounded-[2.5rem] text-white animate-card shadow-xl">
                                            <div className="flex items-center gap-2 mb-3">
                                                <i className="fa-solid fa-gavel text-emerald-400 text-xs"></i>
                                                <span className="text-[9px] font-black uppercase tracking-widest text-emerald-400">Justificación Técnica</span>
                                            </div>
                                            <p className="text-[11px] font-medium leading-relaxed opacity-90 italic">"{test.questions[test.current].expl}"</p>
                                        </div>
                                    )}

                                    {test.answers[test.current] === -1 && (
                                        <div className="mt-8 p-4 bg-orange-50 border border-orange-200 rounded-2xl text-orange-700 text-center animate-pulse">
                                            <p className="text-[10px] font-black uppercase">Contestada en Blanco</p>
                                        </div>
                                    )}
                                </div>

                                <div className="flex gap-4 mt-8">
                                    <button onClick={() => setTest(t => ({...t, current: Math.max(0, t.current - 1)}))} className="flex-1 bg-white border border-slate-200 py-6 rounded-[2.5rem] font-black text-[9px] uppercase shadow-sm active-scale text-slate-400 tracking-widest">Atrás</button>
                                    
                                    {test.answers[test.current] === undefined ? (
                                        <button onClick={() => handleAnswer(-1)} className="flex-[2] bg-slate-100 text-slate-400 py-6 rounded-[2.5rem] font-black text-[9px] uppercase active-scale tracking-widest">En Blanco</button>
                                    ) : (
                                        <button 
                                            onClick={() => {
                                                if(test.current < test.questions.length - 1) setTest(t => ({...t, current: t.current + 1}));
                                                else setView('results');
                                            }}
                                            className="flex-[2] bg-[#043d26] text-white py-6 rounded-[2.5rem] font-black text-[9px] uppercase shadow-2xl active-scale tracking-widest"
                                        >
                                            Siguiente
                                        </button>
                                    )}
                                </div>
                            </div>
                        )}

                        {view === 'results' && (
                            <div className="text-center py-10 px-6 animate-card">
                                <div className="w-52 h-52 bg-white rounded-full flex items-center justify-center mx-auto mb-12 border-[14px] border-emerald-50 shadow-2xl relative">
                                    <div className="text-center">
                                        <div className="text-6xl font-black text-[#043d26]">
                                            {Math.round((Object.values(test.answers).filter((a, i) => a === test.questions[i]?.correct).length / Math.max(1, test.questions.length)) * 100)}%
                                        </div>
                                        <div className="text-[10px] font-black text-slate-300 uppercase mt-1 tracking-widest">Aptitud</div>
                                    </div>
                                    <div className="absolute -bottom-4 bg-emerald-600 text-white px-6 py-2 rounded-full font-black text-[9px] uppercase tracking-widest shadow-xl">Informe Final</div>
                                </div>
                                <h2 className="text-3xl font-black text-slate-800 mb-2 uppercase italic tracking-tighter">SIMULACRO COMPLETADO</h2>
                                <div className="grid grid-cols-3 gap-3 mb-12">
                                    <div className="bg-emerald-50 p-4 rounded-3xl">
                                        <div className="text-emerald-600 font-black text-xl">{Object.values(test.answers).filter((a, i) => a === test.questions[i]?.correct).length}</div>
                                        <div className="text-[8px] font-black text-emerald-400 uppercase">Bien</div>
                                    </div>
                                    <div className="bg-red-50 p-4 rounded-3xl">
                                        <div className="text-red-500 font-black text-xl">{Object.values(test.answers).filter((a, i) => a !== -1 && a !== test.questions[i]?.correct).length}</div>
                                        <div className="text-[8px] font-black text-red-400 uppercase">Mal</div>
                                    </div>
                                    <div className="bg-orange-50 p-4 rounded-3xl">
                                        <div className="text-orange-400 font-black text-xl">{Object.values(test.answers).filter(a => a === -1).length}</div>
                                        <div className="text-[8px] font-black text-orange-400 uppercase">Blanco</div>
                                    </div>
                                </div>
                                <button onClick={() => setView('home')} className="w-full bg-[#043d26] text-white py-6 rounded-[2.5rem] font-black shadow-2xl active-scale uppercase tracking-[0.2em] text-[10px]">Cerrar Informe</button>
                            </div>
                        )}
                    </main>

                    {view === 'home' && (
                        <nav className="fixed bottom-6 left-6 right-6 h-20 bg-[#043d26] rounded-[2.5rem] shadow-2xl flex items-center justify-around px-4 z-[100] border border-white/10">
                            <button className="flex-1 flex flex-col items-center gap-1 text-emerald-400 nav-active pt-2">
                                <i className="fa-solid fa-graduation-cap text-lg"></i>
                                <span className="text-[8px] font-black uppercase tracking-widest">Academia</span>
                            </button>
                            <button className="flex-1 flex flex-col items-center gap-1 text-white/30 pt-2">
                                <i className="fa-solid fa-chart-pie text-lg"></i>
                                <span className="text-[8px] font-black uppercase tracking-widest">Progreso</span>
                            </button>
                            <button className="flex-1 flex flex-col items-center gap-1 text-white/30 pt-2">
                                <i className="fa-solid fa-shield-halved text-lg"></i>
                                <span className="text-[8px] font-black uppercase tracking-widest">Rango</span>
                            </button>
                        </nav>
                    )}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>

